generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ExpenseStatus {
  ACTIVE
  INACTIVE
}

enum InvestmentStatus {
  ACTIVE
  REDEEMED
}

model User {
  id           String     @id @default(cuid())
  code         Int        @unique @default(autoincrement())
  login        String     @unique
  name         String
  email        String     @unique
  passwordHash String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  @@map("users")
}

model Expense {
  id              String           @id @default(cuid())
  code            Int              @unique @default(autoincrement())
  description     String           @unique
  status          ExpenseStatus    @default(ACTIVE)
  payableAccounts PayableAccount[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  @@map("expenses")
}

model PayableAccount {
  id             String    @id @default(cuid())
  code           Int       @unique @default(autoincrement())
  referenceMonth DateTime
  expenseDate    DateTime
  description    String
  expenseId      String?
  expense        Expense?  @relation(fields: [expenseId], references: [id], onDelete: SetNull)
  amount         Decimal   @db.Decimal(12, 2)
  paid           Boolean   @default(false)
  paymentDate    DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([referenceMonth])
  @@index([expenseId])
  @@map("payable_accounts")
}

model Investment {
  id              String           @id @default(cuid())
  code            Int              @unique @default(autoincrement())
  type            String
  institution     String
  description     String
  amount          Decimal          @db.Decimal(12, 2)
  applicationDate DateTime
  maturityDate    DateTime?
  profitability   String?
  notes           String?
  status          InvestmentStatus @default(ACTIVE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  @@map("investments")
}
